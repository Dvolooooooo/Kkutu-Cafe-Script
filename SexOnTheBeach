-- TurnLetter 텍스트를 읽어옵니다. "리(이)" 처럼 괄호 병기 형태면 두 글자를
-- 모두 반환합니다 (앞 글자, 괄호 안 글자). 괄호 문자 종류(반각/전각)나 공백에
-- 영향받지 않도록, 텍스트 안의 한글 덩어리를 순서대로 모두 뽑아서 처리합니다.
local function readTurnLetters()
    local lbl = getTurnLetterLabel()
    if not lbl then return nil, nil end
    local ok, text = pcall(function() return lbl.Text end)
    if not ok or type(text) ~= "string" then return nil, nil end
    text = text:match("^%s*(.-)%s*$") or text
    if text == "" then return nil, nil end

    -- 텍스트 안에 있는 한글 덩어리를 순서대로 전부 수집 (괄호 문자 종류에 의존하지 않음)
    local groups = {}
    for grp in text:gmatch("[가-힣]+") do
        table.insert(groups, grp)
    end
    if #groups == 0 then return nil, nil end

    -- 각 덩어리는 시작 글자(첫 음절)만 사용
    local function firstSyllable(s)
        for _, c in utf8.codes(s) do return utf8.char(c) end
        return s
    end

    local main = firstSyllable(groups[1])
    local alt = groups[2] and firstSyllable(groups[2]) or nil
    if alt == main then alt = nil end
    return main, alt
end

local SUBMIT_ID_AUTO_INCREMENT = false  -- true면 제출마다 id를 1씩 증가시켜 보냄

local function fireSubmitWord(word)
    local ok, remotes = pcall(function()
        return ReplicatedStorage:WaitForChild("KkutuRemotes", 5)
    end)
    if not ok or not remotes then
        warn("KkutuRemotes 폴더를 못 찾음")
        return false
    end
    local okR, remote = pcall(function()
        return remotes:WaitForChild("SubmitWord", 5)
    end)
    if not okR or not remote then
        warn("SubmitWord 리모트를 못 찾음")
        return false
    end
    local idToSend = SUBMIT_ID
    local args = { word, { id = idToSend } }
    local sentOk = pcall(function()
        remote:FireServer(unpack(args))
    end)
    if sentOk and SUBMIT_ID_AUTO_INCREMENT then
        SUBMIT_ID = SUBMIT_ID + 1
    end
    return sentOk
end

-- ============================================================
-- [ 끄투 단어목록 사용 여부 (사전 검색의 injeong 파라미터로 반영) ]
-- ON이면 검색 리모트 호출 시 injeong=true(게임이 인정한 단어만),
-- OFF면 injeong=false(인정 여부 무관)로 요청합니다.
-- ============================================================
local kkutuWordsEnabled = true -- 기본값: 켜짐

-- ============================================================
-- [ 사전 검색 리모트 ]
-- game:GetService("ReplicatedStorage"):WaitForChild("KkutuRemotes")
--     :WaitForChild("RequestDictionarySearch"):InvokeServer(unpack(args))
-- args = {{ query = startChar, sort = sortMode, page = pageNum, injeong = kkutuWordsEnabled }}
-- query에는 시작 글자만 그대로 넣습니다("?" 붙이지 않음).
-- injeong은 끄투 단어목록 토글 상태를 그대로 반영합니다(끄투 켜짐=true →
-- 인정 단어만, 꺼짐=false → 인정 여부 무관).
-- 게임 UI처럼 hasMore가 true면 page를 1씩 늘려가며 계속 더 불러올 수
-- 있습니다("스크롤해야 더 나오는" 것과 동일한 페이지네이션 방식).
-- ============================================================

-- startChar로 시작하는 단어들을 사전 검색 리모트에서 한 페이지 받아옵니다.
-- 반환값: words(테이블 또는 nil), hasMore(boolean)
-- 최적화: 캐시로 리모트 참조 재사용
local _cachedRemotes = nil
local _cachedSearchRemote = nil

local function remoteSearchPage(startChar, sortMode, pageNum)
    -- 캐시된 리모트 참조 사용 (없으면 처음에만 WaitForChild)
    if not _cachedRemotes then
        local ok, remotes = pcall(function()
            return ReplicatedStorage:WaitForChild("KkutuRemotes", 5)
        end)
        if not ok or not remotes then return nil, false end
        _cachedRemotes = remotes
    end
    
    if not _cachedSearchRemote then
        local okR, remote = pcall(function()
            return _cachedRemotes:WaitForChild("RequestDictionarySearch", 5)
        end)
        if not okR or not remote then return nil, false end
        _cachedSearchRemote = remote
    end

    local args = {
        {
            query = startChar,
            sort = sortMode,
            page = pageNum,
            injeong = kkutuWordsEnabled,
        }
    }

    local okI, result = pcall(function()
        return _cachedSearchRemote:InvokeServer(unpack(args))
    end)
    if not okI or type(result) ~= "table" or not result.ok then return nil, false end
    if type(result.words) ~= "table" then return nil, false end
    return result.words, result.hasMore == true
end

-- ============================================================
-- [ 점진적 페이지 로딩 방식 ]
-- 한 번에 모든 페이지를 긁지 않고, "필요할 때만" 다음 페이지를 추가로 로드합니다.
--
-- 동작 방식:
--   1. 처음에는 page 0만 검색
--   2. page 0의 단어를 다 썼으면 → page 1 추가 로드 (page 0 결과는 캐시에 유지)
--   3. page 1의 단어를 다 썼으면 → page 2 추가 로드
--   4. "리셋" 버튼 → 모든 캐시 초기화 → 다시 page 0부터
-- ============================================================

local REMOTE_SEARCH_MAX_PAGES = 10

-- 글자 + 정렬방식별 캐시 상태
-- cacheWords[sortMode][startChar] = 누적된 단어 리스트 (table)
-- cacheNextPage[sortMode][startChar] = 다음에 로드할 페이지 번호
-- cacheExhausted[sortMode][startChar] = true면 더 이상 페이지 없음 (hasMore=false)
local cacheWords = {}
local cacheNextPage = {}
local cacheExhausted = {}

-- 특정 글자의 특정 페이지를 1회 로드
-- "교체" 방식: 이전 페이지 캐시를 버리고 새 페이지로 교체
-- 반환: 로드한 단어 수 (0이면 빈 페이지 or 실패)
local function loadNextPage(startChar, sortMode)
    -- 캐시 구조 초기화 (첫 호출 시)
    if not cacheWords[sortMode] then
        cacheWords[sortMode] = {}
        cacheNextPage[sortMode] = {}
        cacheExhausted[sortMode] = {}
    end

    -- 이미 더 이상 페이지가 없음이 확인됐으면 스킵
    if cacheExhausted[sortMode][startChar] then return 0 end

    local nextPage = cacheNextPage[sortMode][startChar] or 0
    if nextPage >= REMOTE_SEARCH_MAX_PAGES then
        cacheExhausted[sortMode][startChar] = true
        return 0
    end

    local words, hasMore = remoteSearchPage(startChar, sortMode, nextPage)
    cacheNextPage[sortMode][startChar] = nextPage + 1

    -- 이전 페이지 캐시를 버리고 새 페이지로 교체
    cacheWords[sortMode][startChar] = {}
    local added = 0
    if words and #words > 0 then
        for _, w in ipairs(words) do
            table.insert(cacheWords[sortMode][startChar], w)
            added = added + 1
        end
    end

    if not hasMore then
        cacheExhausted[sortMode][startChar] = true
    end

    return added
end

-- 현재까지 로드된 단어들을 반환 (없으면 nil)
local function getCurrentlyLoadedWords(startChar, sortMode)
    if not cacheWords[sortMode] then return nil end
    return cacheWords[sortMode][startChar]
end

-- 초기화: 특정 글자의 캐시를 비움 (리셋 버튼에서 사용)
local function clearCharCache(startChar, sortMode)
    if cacheWords[sortMode] then cacheWords[sortMode][startChar] = nil end
    if cacheNextPage[sortMode] then cacheNextPage[sortMode][startChar] = nil end
    if cacheExhausted[sortMode] then cacheExhausted[sortMode][startChar] = nil end
end

-- 시작 문자에 대해 최소 1페이지는 로드되어 있는지 보장
local function ensureFirstPageLoaded(startChar, sortMode)
    if not cacheWords[sortMode] then
        cacheWords[sortMode] = {}
        cacheNextPage[sortMode] = {}
        cacheExhausted[sortMode] = {}
    end
    if cacheWords[sortMode][startChar] == nil and not cacheExhausted[sortMode][startChar] then
        loadNextPage(startChar, sortMode)
    end
end

-- ============================================================
-- [ WindUI 라이브러리 로드 ]
-- 깃허브에서 코드를 받아오는 과정이라 네트워크 상태에 따라 실패할 수 있습니다.
--
-- [ 무한로딩 근본 원인 ]
-- WindUI 내부와, WindUI가 자동으로 불러오는 아이콘 모듈(Icons/Main-v2.lua)
-- 안에는 "진짜 익스플로잇 실행기가 맞는지"를 판단해서 분기하는 코드가 있는데,
-- 그 판단 기준이 되는 전역 함수(writefile, request)가 사용자의 실행기에
-- 없으면(또는 실행기가 그 함수들을 지원 안 하면), "이 게임에는 존재하지
-- 않는" 리모트(GetIcons/Loadstring/Request)를 WaitForChild(..., 9999~99999)
-- 로 무한대기하는 코드 경로를 타버립니다. 리모트가 영원히 안 생기니
-- WaitForChild가 영원히 안 끝나고, 그 뒤의 UI 생성 코드가 통째로 멈춥니다.
--
-- [ 해결 방법 ]
-- WindUI를 부르기 "전에" 이 함수들이 없으면 안전한 더미 함수로 미리 채워
-- 넣어서, WindUI/아이콘 모듈이 "정상적인 실행기다"라고 판단하게 만들어
-- 애초에 그 위험한 무한대기 분기 자체를 타지 않도록 막습니다.
-- (더미 request는 실제로 호출되지 않고 "존재하는지 여부"만 검사당하므로
-- 안전합니다. writefile 계열 더미는 실제 파일 저장은 안 되지만 최소한
-- 멈추지는 않습니다.)
-- 그래도 혹시 모를 상황을 대비해 타임아웃 감시 + 재시도는 유지합니다.
-- ============================================================
if not request then
    request = function(opts) return { Success = false, StatusCode = 0, Body = "" } end
end
if not writefile then
    writefile = function(path, data) end
end
if not readfile then
    readfile = function(path) return "" end
end
if not isfile then
    isfile = function(path) return false end
end
if not isfolder then
    isfolder = function(path) return true end
end
if not makefolder then
    makefolder = function(path) end
end
if not delfile then
    delfile = function(path) end
end

