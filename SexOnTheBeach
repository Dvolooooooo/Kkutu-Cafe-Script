local TURN_SLOT_NAME = "Slot_11030096872"  -- 제출 성공/거부 판정용 스코어보드 슬롯

-- Scoreboard.Slot_11030096872.Card.Content.Meta.Name 값을 읽습니다.
-- 주의: Roblox에서 .Name은 그 오브젝트 자체의 내장 이름 속성(이미 문자열)이라
-- 뒤에 .Text를 붙이면 안 됩니다.
local function getScoreboardTurnName()
    local pg = player:FindFirstChild("PlayerGui")
    if not pg then return nil end
    local hud = pg:FindFirstChild("KkutuHUD")
    if not hud then return nil end
    local scoreboard = hud:FindFirstChild("Scoreboard")
    if not scoreboard then return nil end
    local slot = scoreboard:FindFirstChild(TURN_SLOT_NAME)
