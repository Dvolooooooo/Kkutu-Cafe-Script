local function addRecent(word)
    table.insert(recentWords, 1, word)
    if #recentWords > 20 then table.remove(recentWords) end
end
local function wasRecent(word)
    for _, v in ipairs(recentWords) do
        if v == word then return true end
    end
    return false
end

-- 단어 로드
-- 지원하는 원본 형식 2가지:
--   1) JSON 형식: "단어" 패턴이 큰따옴표로 감싸져 있음
--   2) 일반 텍스트: 줄바꿈으로 단어가 나열됨
--   3) "[글자]" 헤더 아래 "깊이 N : 단어, 단어, ..." 또는 "돌림 : 단어, ..."
--      형식 (끄투 필수공격/공격/방어 단어 파일). "깊이"/"돌림" 라벨 자체가
--      한글이라서 줄 전체를 스캔하면 안 되고, 콜론(:) 뒤의 단어 목록만
--      쉼표로 나눠서 정확히 추출해야 오염되지 않습니다.
local function addWordToDict(wordSet, data, w)
    if w == "" or wordSet[w] or isDeleted(w) or not validWord(w) then return false end
    wordSet[w] = true
    local f = firstChar(w)
    dictionary[f] = dictionary[f] or {}
    table.insert(dictionary[f], w)
    if data.priority == 1 then
        essentialDictionary[f] = essentialDictionary[f] or {}
        table.insert(essentialDictionary[f], w)
        essentialSet[w] = true
    elseif data.priority == 2 then
        attackDictionary[f] = attackDictionary[f] or {}
        table.insert(attackDictionary[f], w)
        attackSet[w] = true
    elseif data.priority == 3 then
        defDictionary[f] = defDictionary[f] or {}
        table.insert(defDictionary[f], w)
        defSet[w] = true
    else
        normalDictionary[f] = normalDictionary[f] or {}
        table.insert(normalDictionary[f], w)
    end
    -- 끄투 계열 출처면 별도 집합에도 표시 (마스터 스위치 OFF 시 실시간으로 걸러내기 위함)
    if data.isKkutu then
        kkutuWordSet[w] = true
    end
    return true
end

-- 끄투 4개 출처는 항상 사전에는 로드해두고(재로드 없이 즉시 ON/OFF 하기 위해),
-- 실제 사용 시점에 isKkutuDisabled()로 걸러냅니다. 그래서 여기서는 별도의
-- ON/OFF 필터링 없이 모든 WORDS_URLS를 그대로 로드합니다.
local function loadWords()
    dictionary = {}; essentialDictionary = {}; attackDictionary = {}
    defDictionary = {}; normalDictionary = {}
    essentialSet = {}; attackSet = {}; defSet = {}
    killable = {}; wordScore = {}
    kkutuWordSet = {}
    local total = 0
    local wordSet = {}

    for _, data in ipairs(WORDS_URLS) do
        local ok, con = pcall(function() return game:HttpGet(data.url) end)
        if ok and type(con) == "string" then
            -- 1) JSON 형식 파싱
            for w in con:gmatch('"([^"]+)"') do
                w = w:match("^%s*(.-)%s*$")
                if addWordToDict(wordSet, data, w) then total = total + 1 end
            end
            -- 2) & 3) 줄 단위 파싱: "깊이 N : 단어들" / "돌림 : 단어들" 형식과
            -- 일반 텍스트 줄 형식을 모두 처리
            for line in con:gmatch("[^\r\n]+") do
                if not line:find('"') and not line:match("^%[") then
                    local afterColon = line:match("^%s*깊이%s*%d+%s*:%s*(.+)$")
                        or line:match("^%s*돌림%s*:%s*(.+)$")
                    if afterColon then
                        -- 콜론 뒤 쉼표로 구분된 단어들만 추출 (라벨 오염 방지)
                        for w in afterColon:gmatch("[^,]+") do
                            w = w:match("^%s*(.-)%s*$")
                            if addWordToDict(wordSet, data, w) then total = total + 1 end
                        end
                    else
                        for w in line:gmatch("[가-힣]+") do
                            if addWordToDict(wordSet, data, w) then total = total + 1 end
                        end
                    end
                end
            end
        end
        task.wait()
    end
    return total
end


-- 점수 계산
local function calcScores()
    killable = {}; wordScore = {}
    for sc, wl in pairs(dictionary) do
        for _, w in ipairs(wl) do
            if not hasWordStarting(lastChar(w)) then
                killable[sc] = true
                break
            end
        end
    end
    local function atkBonus(w)
        if essentialSet[w] then return 500
        elseif attackSet[w] then return 200
        elseif defSet[w] then return 50
        else return 0 end
    end
    for _, wl in pairs(dictionary) do
        for _, w in ipairs(wl) do
            if not wordScore[w] then
                local lc = lastChar(w)
                local bonus = atkBonus(w)
                local ec = 0; local opLC = {}; local seenLC = {}; local tooMany = false
                for _, v in ipairs(getDuumVariants(lc)) do
                    if tooMany then break end
                    local ol = dictionary[v]
                    if ol then
                        ec = ec + #ol
                        for _, ow in ipairs(ol) do
                            local o = lastChar(ow)
                            if not seenLC[o] then
                                seenLC[o] = true
                                table.insert(opLC, o)
                                if #opLC >= 20 then tooMany = true; break end
                            end
                        end
                    end
                end
                local score
                if ec == 0 then
                    score = 100000 + bonus
                elseif tooMany then
                    score = -math.min(ec, 200) * 5 + bonus
                else
                    local is2K = true
                    for _, o in ipairs(opLC) do
                        local k = false
                        for _, v in ipairs(getDuumVariants(o)) do
                            if killable[v] then k = true; break end
                        end
                        if not k then is2K = false; break end
                    end
                    score = (is2K and 10000 or 0) - math.min(ec, 200) * 5 + bonus
                end
                wordScore[w] = score
            end
        end
    end
end

-- 상위 후보 중 가중치 랜덤 (패턴 방지)
local RANDOM_TOP_N = 8

local function pickFromTop(candidates, topN)
    if #candidates == 0 then return nil end
    topN = math.min(topN or RANDOM_TOP_N, #candidates)
    table.sort(candidates, function(a, b) return (wordScore[a] or 0) > (wordScore[b] or 0) end)
    local weights = {}; local totalW = 0
    for i = 1, topN do
        local w = math.max(1, (wordScore[candidates[i]] or 0) + 200000)
        weights[i] = w
        totalW = totalW + w
    end
    local r = math.random() * totalW
    local cum = 0
    for i = 1, topN do
        cum = cum + weights[i]
        if r <= cum then return candidates[i] end
    end
    return candidates[topN]
end

-- 단어 찾기
local function findBestWord(sc)
    local cands = {}
    for _, v in ipairs(getDuumVariants(sc)) do
        for _, dict in ipairs({essentialDictionary[v], attackDictionary[v], dictionary[v]}) do
            if dict then
                for _, w in ipairs(dict) do
                    if not isUsed(w) and not isOpeningBlockedWord(w) and not isKkutuDisabled(w) and (wordScore[w] or 0) >= 100000 then
                        table.insert(cands, w)
                    end
                end
            end
        end
    end
    return pickFromTop(cands, RANDOM_TOP_N)
end

-- 노멀 모드: "더 어려운(공격적인) 단어"를 우선 선택하도록 점수 가중치를 강화해서 정렬
local function findNormalWord(sc)
    local cands = {}
    for _, v in ipairs(getDuumVariants(sc)) do
        local list = dictionary[v]
        if list then
            for _, w in ipairs(list) do
                if not isUsed(w) and not wasRecent(w) and not isOpeningBlockedWord(w) and not isKkutuDisabled(w) then
                    table.insert(cands, w)
                end
            end
        end
    end
    if #cands == 0 then return nil end
    -- 점수(공격성) 내림차순 정렬 후 상위권에서만 선택 = 더 어려운 단어 우선
    table.sort(cands, function(a, b) return (wordScore[a] or 0) > (wordScore[b] or 0) end)
    local topN = math.min(5, #cands)
    return cands[math.random(1, topN)]
end

-- 긴단어 모드: 두 시작 글자(두음 병기 포함) 후보들을 모두 비교해서 그 중 가장 긴 단어를 선택
local function findLongestWord(sc)
    local function collect(startChar, applyOpeningBlock)
        local cands = {}
        for _, v in ipairs(getDuumVariants(startChar)) do
            local list = dictionary[v]
            if list then
                for _, w in ipairs(list) do
                    if not isUsed(w) and not wasRecent(w) and not isKkutuDisabled(w) then
                        if not applyOpeningBlock or not isOpeningBlockedWord(w) then
                            table.insert(cands, w)
                        end
                    end
                end
            end
        end
        return cands
    end

    local cands = collect(sc, true)
    if #cands == 0 then
        cands = collect(sc, false)
    end
    if #cands == 0 then return nil end

    local maxLen = 0
    for _, w in ipairs(cands) do
        local l = utf8.len(w) or #w
        if l > maxLen then maxLen = l end
    end

    local longest = {}
    for _, w in ipairs(cands) do
        local l = utf8.len(w) or #w
        if l == maxLen then table.insert(longest, w) end
    end
    table.sort(longest, function(a, b) return (wordScore[a] or 0) > (wordScore[b] or 0) end)

    local topN = math.min(5, #longest)
    return longest[math.random(1, topN)]
end

local function findEasyWord(sc)
    local cands = {}
    local seen = {}
    local function tryList(list)
        if not list then return end
        for _, w in ipairs(list) do
            if not seen[w] and not isUsed(w) and not wasRecent(w) and not isDeleted(w) and not isKkutuDisabled(w) then
                local s = wordScore[w] or 0
                if s < 10000 and essentialSet[w] ~= true and attackSet[w] ~= true then
                    seen[w] = true
                    table.insert(cands, w)
                end
            end
        end
    end
    for _, v in ipairs(getDuumVariants(sc)) do tryList(normalDictionary[v] or dictionary[v]) end
    if #cands == 0 then
        for _, v in ipairs(getDuumVariants(sc)) do
            local list = dictionary[v]
            if list then
                for _, w in ipairs(list) do
                    if not seen[w] and not isUsed(w) and not wasRecent(w) and not isDeleted(w) and not isKkutuDisabled(w) then
                        seen[w] = true
                        table.insert(cands, w)
                    end
                end
            end
        end
    end
    if #cands == 0 then return nil end
    table.sort(cands, function(a, b)
        local sa, sb = wordScore[a] or 0, wordScore[b] or 0
        if sa ~= sb then return sa < sb end
        return #a < #b
    end)
    local topN = math.min(12, #cands)
    return cands[math.random(1, topN)]
end

-- RACE 그래프 알고리즘 v2 데이터셋 연동판
local raceBuilt = false
local raceTrueCounts = false
local raceCount = {}
local racePools = {}
local raceIn = {}
local raceNodes = {}
local raceLabelCache = nil
local raceRankCache = nil
local raceOutCache = {}
local raceEdgeCache = {} -- findRaceWord()의 글자별 분류/정렬 결과 캐시 (성능 최적화)
local RACE_DATA_BASE = "https://gist.githubusercontent.com/GUMI2029/fecbfae5a7d44423a882002df65de3d2/raw"
local RACE_CACHE_VERSION = "20260704_race_auto"

local function raceLoadJSON(fileName)
    local HttpService = game:GetService("HttpService")
    local cacheName = "kkutu_" .. fileName:gsub("%.", "_") .. "_" .. RACE_CACHE_VERSION .. ".json"
    if isfile and readfile and isfile(cacheName) then
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile(cacheName))
        end)
        if ok and data then return data end
    end
    local ok, body = pcall(function()
        return game:HttpGet(RACE_DATA_BASE .. "/" .. fileName)
    end)
    if ok and type(body) == "string" and #body > 10 then
        local ok2, data = pcall(function()
            return HttpService:JSONDecode(body)
        end)
        if ok2 and data then
            pcall(function()
                if writefile then writefile(cacheName, body) end
            end)
            return data
        end
    end
    return nil
end

local function raceWordStartsForPrompt(word, letter)
    local f = firstChar(word)
    for _, s in ipairs(getDuumVariants(letter)) do
        if f == s then return true end
    end
    return false
end

local function raceBuildGraph()
    if raceBuilt then return end
    raceBuilt = true
    raceCount = {}; racePools = {}; raceIn = {}; raceNodes = {}
    raceLabelCache = nil; raceRankCache = nil; raceOutCache = {}

    local rd = raceLoadJSON("racedata.json")
    if rd and type(rd.counts) == "table" then
        raceCount = rd.counts
        racePools = rd.pools or {}
        raceTrueCounts = true
    else
        for startChar, list in pairs(dictionary) do
            for _, w in ipairs(list) do
                if validWord(w) and not isDeleted(w) then
                    local a = firstChar(w)
                    local b = lastChar(w)
                    raceCount[a] = raceCount[a] or {}
                    raceCount[a][b] = (raceCount[a][b] or 0) + 1
                end
            end
        end
    end

    local seenNode = {}
    local function addNode(x)
        if x and not seenNode[x] then
            seenNode[x] = true
            table.insert(raceNodes, x)
        end
    end
    for a, row in pairs(raceCount) do
        addNode(a)
        for b, cnt in pairs(row) do
            if cnt and cnt > 0 then
                addNode(b)
                raceIn[b] = raceIn[b] or {}
                raceIn[b][a] = true
            end
        end
    end
    print("[RaceAuto] graph nodes=" .. tostring(#raceNodes) .. " counts=" .. (raceTrueCounts and "TRUE" or "approx"))
end

local function raceOutCapacity(letter)
    raceBuildGraph()
    if raceOutCache[letter] ~= nil then return raceOutCache[letter] end
    local n = 0
    local checked = {}
    for _, s in ipairs(getDuumVariants(letter)) do
        if not checked[s] then
            checked[s] = true
            local row = raceCount[s]
            if row then
                for _, cnt in pairs(row) do
                    if cnt and cnt > 0 then n = n + cnt end
                end
            end
        end
    end
    raceOutCache[letter] = n
    return n
end

local function raceReplyCount(word)
    if not word then return 0 end
    return raceOutCapacity(lastChar(word))
end

local function raceRelabel()
    raceBuildGraph()
    if raceLabelCache and raceRankCache then return raceLabelCache, raceRankCache end
    local label = {}
    local rank = {}
    local undec = {}
    local q = {}
    local head = 1
    for _, u in ipairs(raceNodes) do
        local out = 0
        local row = raceCount[u]
        if row then
            for _, cnt in pairs(row) do
                if cnt and cnt > 0 then out = out + 1 end
            end
        end
        undec[u] = out
        if out == 0 then
            label[u] = "L"
            rank[u] = 0
            table.insert(q, u)
        end
    end
    while head <= #q do
        local y = q[head]
        head = head + 1
        local ins = raceIn[y]
        if ins then
            for x in pairs(ins) do
                if label[x] == nil then
                    if label[y] == "L" then
                        label[x] = "W"
                        rank[x] = (rank[y] or 0) + 1
                        table.insert(q, x)
                    else
                        undec[x] = (undec[x] or 1) - 1
                        if undec[x] <= 0 then
                            label[x] = "L"
                            rank[x] = (rank[y] or 0) + 1
                            table.insert(q, x)
                        end
                    end
                end
            end
        end
    end
    raceLabelCache = label
    raceRankCache = rank
    return label, rank
end

local function raceUsableWord(word, letter, ce, openingSafe)
    if not word or isUsed(word) or wasRecent(word) or isDeleted(word) or isKkutuDisabled(word) then return false end
    if not validWord(word) then return false end
    if not raceWordStartsForPrompt(word, letter) then return false end
    if ce and lastChar(word) ~= ce then return false end
    if openingSafe and isOpeningBlockedWord(word) then return false end
    if openingSafe and raceReplyCount(word) <= 0 then return false end
    if openingSafe and OPENER_DEAD_START_LETTERS[firstChar(word)] then return false end
    if openingSafe and OPENER_BAD_WORDS[word] then return false end
    return true
end

local function raceWordForEdge(letter, cs, ce, openingSafe)
    local prow = racePools[cs]
    local pool = prow and prow[ce]
    if pool then
        for _, w in ipairs(pool) do
            if raceUsableWord(w, letter, ce, openingSafe) then return w end
        end
    end
    local list = dictionary[cs]
    if list then
        for _, w in ipairs(list) do
            if raceUsableWord(w, letter, ce, openingSafe) then return w end
        end
    end
    for _, s in ipairs(getDuumVariants(letter)) do
        list = dictionary[s]
        if list then
            for _, w in ipairs(list) do
                if raceUsableWord(w, letter, ce, openingSafe) then return w end
            end
        end
    end
    return nil
end

local function racePickEdgeWord(letter, edges, openingSafe)
    for i = 1, math.min(6, #edges) do
        local e = edges[i]
        local w = raceWordForEdge(letter, e.cs, e.ce, openingSafe)
        if w then
            addRecent(w)
            return w
        end
    end
    return nil
end

local function raceCandidateFallback(letter, openingSafe)
    local cands = {}
    local seen = {}
    for _, s in ipairs(getDuumVariants(letter)) do
        local list = dictionary[s]
        if list then
            for _, w in ipairs(list) do
                if not seen[w] and raceUsableWord(w, letter, nil, openingSafe) then
                    seen[w] = true
                    table.insert(cands, w)
                end
            end
        end
    end
    if #cands == 0 then return nil end
    table.sort(cands, function(a, b)
        local ra, rb = raceReplyCount(a), raceReplyCount(b)
        if ra ~= rb then return ra < rb end
        return (wordScore[a] or 0) > (wordScore[b] or 0)
    end)
    local w = cands[math.random(1, math.min(8, #cands))]
    if w then addRecent(w) end
    return w
end

local function findRaceWord(letter, openingSafe)
    raceBuildGraph()
    local label, rank = raceRelabel()

    -- 성능 최적화: 같은 글자(+openingSafe 상태)에 대한 분류/정렬 결과를
    -- 캐싱해서, 재시도 루프에서 반복 호출될 때마다 매번 다시 계산하지
    -- 않도록 합니다. (이게 없으면 노멀모드에서 랙이 심하게 걸림)
    local cacheKey = letter .. "|" .. tostring(openingSafe)
    local cached = raceEdgeCache[cacheKey]

    local kill, yudo, safe, risk
    if cached then
        kill, yudo, safe, risk = cached.kill, cached.yudo, cached.safe, cached.risk
    else
        kill, yudo, safe, risk = {}, {}, {}, {}
        local checked = {}

        for _, cs in ipairs(getDuumVariants(letter)) do
            if not checked[cs] then
                checked[cs] = true
                local row = raceCount[cs]
                if row then
                    for ce, cnt in pairs(row) do
                        if cnt and cnt > 0 then
                            local e = {cs = cs, ce = ce, reply = raceOutCapacity(ce), rank = rank[ce] or 999999}
                            if openingSafe and e.reply < RACE_OPEN_MIN_OPP then
                                -- 첫 턴: 착지 자리에 응수가 너무 적으면 후보 제외
                            elseif (not openingSafe) and e.reply <= 0 then
                                table.insert(kill, e)
                            elseif label[ce] == "L" then
                                if not openingSafe then
                                    table.insert(yudo, e)
                                end
                            elseif label[ce] == "W" then
                                table.insert(risk, e)
                            else
                                table.insert(safe, e)
                            end
                        end
                    end
                end
            end
        end

        table.sort(kill, function(a, b) return a.reply < b.reply end)
        table.sort(yudo, function(a, b)
            if a.rank ~= b.rank then return a.rank < b.rank end
            return a.reply < b.reply
        end)
        table.sort(safe, function(a, b)
            if a.reply ~= b.reply then return a.reply < b.reply end
            return a.ce < b.ce
        end)
        table.sort(risk, function(a, b)
            if a.rank ~= b.rank then return a.rank > b.rank end
            return a.reply < b.reply
        end)

        raceEdgeCache[cacheKey] = {kill = kill, yudo = yudo, safe = safe, risk = risk}
    end

    local w = racePickEdgeWord(letter, kill, openingSafe)
    if w then return w end

    w = racePickEdgeWord(letter, yudo, openingSafe)
    if w then return w end

    w = racePickEdgeWord(letter, safe, openingSafe)
    if w then return w end

    w = racePickEdgeWord(letter, risk, openingSafe)
    if w then return w end

    return raceCandidateFallback(letter, openingSafe)
end

task.spawn(function()
    task.wait(0.5)
    pcall(function()
        raceBuildGraph()
        raceRelabel()
    end)
end)

-- ============================================================
-- [ 단어 생성 진입점 ]
-- primaryChar: TurnLetter의 주 글자
-- altChar: 두음 병기("력(역)")의 괄호 안 글자 (없으면 nil)
-- 두 글자 모두에서 후보를 뽑아 비교합니다:
--   - 노멀 모드: 더 어려운(점수 높은) 단어 우선
--   - 긴단어 모드: 둘 중 더 긴 단어 우선
-- ============================================================
local function pickBetter(mode, wordA, wordB)
    if not wordA then return wordB end
    if not wordB then return wordA end
    if mode == "LONG" then
        local la, lb = utf8.len(wordA) or #wordA, utf8.len(wordB) or #wordB
        if la ~= lb then return la > lb and wordA or wordB end
        return (wordScore[wordA] or 0) >= (wordScore[wordB] or 0) and wordA or wordB
    end
    -- 노멀(기본): 더 어려운(공격적인) 단어 우선
    return (wordScore[wordA] or 0) >= (wordScore[wordB] or 0) and wordA or wordB
end

local function generateWordForChar(sc)
    if mode == "LONG" then
        return findLongestWord(sc) or findNormalWord(sc) or findBestWord(sc)
    end
    local raceWord = findRaceWord(sc, isOpeningSafePhase())
    if raceWord then return raceWord end
    return findNormalWord(sc) or findLongestWord(sc) or findBestWord(sc)
end

local function generateWord(primaryChar, altChar)
    local wordA = generateWordForChar(primaryChar)
    if not altChar then return wordA end
    local wordB = generateWordForChar(altChar)
    return pickBetter(mode, wordA, wordB)
end

-- ============================================================
-- [ 제출 ]
-- 노멀 모드: 단어 1개만 생성해서 리모트를 딱 1번만 쏘고 끝냅니다.
--            (거부 감지/재시도 로직 없음)
-- 긴단어 모드: 기존처럼 거부 감지 + 초고속 재시도 로직을 그대로 사용합니다.
--   1) 첫 단어를 내고 0.1초 기다려서 스코어보드 이름이 바뀌었는지 확인
--   2) 0.1초 안에 안 바뀌면(=거부) 0.001초 간격으로 최대 20번 재시도
--   3) 그래도 다 실패하면 시도했던 단어 중 19개는 다시 쓸 수 있게 풀어줌
--
-- 단어 딜레이: 최소값~최대값 사이에서 매번 무작위로 하나 골라서 그만큼
-- 기다린 뒤 제출합니다. 최소/최대가 비어있거나 둘 다 0이면 딜레이 없이
-- 거의 즉시 제출합니다.
-- ============================================================
local FIRST_CHECK_DELAY = 0.1     -- 첫 제출 후 변경 여부를 확인하는 대기시간(초, 긴단어 모드 전용)
local MAX_SUBMIT_RETRY = 20       -- 거부됐을 때 빠르게 재시도할 최대 횟수(긴단어 모드 전용)
local FAST_RETRY_DELAY = 0.001    -- 빠른 재시도 간격(초, 긴단어 모드 전용)
local RESET_COUNT_ON_FAIL = 19    -- 재시도를 다 썼을 때 다시 풀어줄 단어 개수(긴단어 모드 전용)
local wordDelayMin = 0 -- 단어 딜레이 최소값(초). 비어있거나 0이면 딜레이 없음
local wordDelayMax = 0 -- 단어 딜레이 최대값(초). 비어있거나 0이면 딜레이 없음

local function getWordDelay()
    local mn = tonumber(wordDelayMin) or 0
    local mx = tonumber(wordDelayMax) or 0
    if mn <= 0 and mx <= 0 then return 0 end
    if mn < 0 then mn = 0 end
    if mx < 0 then mx = 0 end
    if mn > mx then mn, mx = mx, mn end
    if mn == mx then return mn end
    return mn + math.random() * (mx - mn)
end

local function submitWord(word, skip)
    local sent = fireSubmitWord(word)
    if not sent then return false end
    usedWords[word] = true
    turnCounter = turnCounter + 2
    return true
end

local function doAutoInput()
    local success, err = pcall(function()
        local delay = getWordDelay()
        if delay > 0 then
            task.wait(delay)
        end

        local main, alt = readTurnLetters()
        if not main then
            return
        end
        lastStartChar = main

        -- 노멀 모드: 단어 1개 생성해서 딱 1번만 제출하고 끝
        if mode == "NORMAL" then
            local word = generateWord(main, alt)
            if word then
                submitWord(word, true)
            end
            return
        end

        -- 긴단어 모드(및 그 외 모드): 거부 감지 + 초고속 재시도 로직
        local beforeName = getScoreboardTurnName()
        local attemptedWords = {}
        local matched = false

        -- 1) 첫 단어 제출 후 0.1초 대기하여 변경 여부 확인
        local firstWord = generateWord(main, alt)
        if firstWord then
            table.insert(attemptedWords, firstWord)
            submitWord(firstWord, true)
            task.wait(FIRST_CHECK_DELAY)

            local afterName = getScoreboardTurnName()
            if beforeName == nil or afterName == nil or afterName ~= beforeName then
                matched = true
            end
        end

        -- 2) 0.1초 안에 안 바뀌었으면(거부) 0.001초 간격으로 초고속 재시도
        if not matched then
            for attempt = 1, MAX_SUBMIT_RETRY do
                local word = generateWord(main, alt)

                if not word then
                    break
                end

                table.insert(attemptedWords, word)
                submitWord(word, true)

                task.wait(FAST_RETRY_DELAY)

                local afterName = getScoreboardTurnName()

                -- 스코어보드 이름을 못 읽는 경우(구조 못 찾음)는 판정 불가 -> 성공으로 간주하고 종료
                if beforeName == nil or afterName == nil then
                    matched = true
                    break
                end

                if afterName ~= beforeName then
                    matched = true
                    break
                end
                -- usedWords에 이미 표시되어 있어서 다음 generateWord는 자동으로 다른 단어를 고름
            end
        end

        -- 재시도를 다 썼는데도 실패했으면, 시도했던 단어 중 일부(RESET_COUNT_ON_FAIL개)를
        -- 다시 쓸 수 있게 풀어줍니다 (너무 많은 단어가 영구히 사라지는 것을 방지)
        if not matched and #attemptedWords > 0 then
            for i = #attemptedWords, 2, -1 do
                local j = math.random(1, i)
                attemptedWords[i], attemptedWords[j] = attemptedWords[j], attemptedWords[i]
            end
            local resetN = math.min(RESET_COUNT_ON_FAIL, #attemptedWords)
            for i = 1, resetN do
                usedWords[attemptedWords[i]] = nil
            end
        end
    end)
    if not success then warn(err) end
end


-- 단어 검색
local currentSearchType = "START"
local function searchWords(query)
    local results = {}
    if not query or query == "" then return results end
    for _, wl in pairs(dictionary) do
        for _, w in ipairs(wl) do
            local match = false
            if currentSearchType == "START" then match = w:sub(1, #query) == query
            elseif currentSearchType == "END" then match = w:sub(-#query) == query
            elseif currentSearchType == "CONTAIN" then match = w:find(query, 1, true) ~= nil
            elseif currentSearchType == "ATTACK" then match = (wordScore[w] or 0) >= 100000 and w:sub(1, #query) == query
            end
            if match and #results < 50 then table.insert(results, w) end
        end
    end
    table.sort(results, function(a, b) return (wordScore[a] or 0) > (wordScore[b] or 0) end)
    return results
end

