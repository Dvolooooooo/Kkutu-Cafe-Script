local SUBMIT_ID = 1  -- WindUI "속도/타이핑" 탭에서 실시간으로 바꿀 수 있음

local function getTurnLetterLabel()
    local pg = player:FindFirstChild("PlayerGui")
    if not pg then return nil end
    local hud = pg:FindFirstChild("KkutuHUD")
    if not hud then return nil end
