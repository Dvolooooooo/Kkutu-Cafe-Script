-- 자동답변 폴링: TurnLetter 텍스트가 이전과 달라질 때마다(=글자가 바뀌면)
-- 자동으로 그 글자로 시작하는 단어를 입력합니다.
-- ══════════════════════════════════════

task.spawn(function()
    while true do
        task.wait(0.2)
        if not autoReply then
            lastTurnLetterText = nil
        else
            local lbl = getTurnLetterLabel()
            local ok, text = pcall(function()
                if not lbl then return nil end
                return lbl.Text
            end)
            if not ok then text = nil end

            if type(text) == "string" and text ~= "" and text ~= lastTurnLetterText then
                lastTurnLetterText = text
                if not isReplying then
                    isReplying = true
                    task.spawn(function()
                        doAutoInput()
                        isReplying = false
                    end)
                end
            end
        end
    end
end)

