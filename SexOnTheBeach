-- 전방 선언: 실제 구현은 파일 뒷부분(단어 로드 섹션)에 있고, WindUI 토글
-- 콜백에서 이 변수를 통해 호출합니다.
local reloadDictionary = function() end


-- 한글 유틸
local CHO = {"ㄱ","ㄲ","ㄴ","ㄷ","ㄸ","ㄹ","ㅁ","ㅂ","ㅃ","ㅅ","ㅆ","ㅇ","ㅈ","ㅉ","ㅊ","ㅋ","ㅌ","ㅍ","ㅎ"}
local function getCho(char)
    local code = utf8.codepoint(char)
    if code >= 44032 and code <= 55203 then
        return CHO[math.floor((code - 44032) / 588) + 1]
    end
    return char
end
local function getChoIndex(char)
    local code = utf8.codepoint(char)
    if code >= 44032 and code <= 55203 then return math.floor((code - 44032) / 588) end
    return nil
end
local function getJungIndex(char)
    local code = utf8.codepoint(char)
    if code >= 44032 and code <= 55203 then return math.floor(((code - 44032) % 588) / 28) end
    return nil
end
local function replaceChoPart(char, newIdx)
    local code = utf8.codepoint(char)
    if code >= 44032 and code <= 55203 then
        return utf8.char(44032 + newIdx * 588 + (code - 44032) % 588)
    end
    return char
end

local N_TO_O = {[2]=true,[3]=true,[6]=true,[7]=true,[12]=true,[17]=true,[20]=true}
local R_TO_O = {[2]=true,[3]=true,[4]=true,[6]=true,[7]=true,[12]=true,[16]=true,[17]=true,[20]=true}

local function getDuumVariants(startChar)
    local ci = getChoIndex(startChar)
    local ji = getJungIndex(startChar)
    if not ci or not ji then return {startChar} end
    local v = {startChar}
    if ci == 2 and N_TO_O[ji] then
        table.insert(v, replaceChoPart(startChar, 11))
    elseif ci == 5 and R_TO_O[ji] then
        table.insert(v, replaceChoPart(startChar, 11))
    end
    return v
end

local function firstChar(word)
    for _, c in utf8.codes(word) do return utf8.char(c) end
    return word
end
local function lastChar(word)
    local t = {}
    for _, c in utf8.codes(word) do table.insert(t, utf8.char(c)) end
    return t[#t]
end
local function validWord(word)
    if #word < 2 then return false end
    for _, c in utf8.codes(word) do
        if c < 44032 or c > 55203 then return false end
    end
    return true
end

