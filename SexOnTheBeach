-- ============================================================
-- [ 긴단어 모드: 검색 리모트 결과 중 가장 긴 단어 선택 ]
-- ============================================================

-- entries(문자열 배열 또는 {word=...} 테이블 배열)에서 아직 안 쓴 것들 중
-- 가장 긴 글자수를 만족하는 것들을 모은 뒤 순수 랜덤으로 하나 선택합니다.
-- (정렬 순서에 의존하지 않고, 매번 같은 것만 나오는 것을 방지하기 위해 랜덤)
-- validWord()로 한글 음절(가~힣)로만 이루어진 단어인지 검사해서 "?" 같은
-- 특수문자가 섞인 항목은 걸러냅니다.
-- expectedStartChar가 주어지면, 검색 리모트가 실제로 그 글자로 "시작하지
-- 않는" 단어를 섞어서 줄 수도 있으므로(예: "기"를 검색했는데 "간"으로
-- 시작하는 단어가 섞여 나오는 경우) 첫 글자가 정확히 일치하는지 다시
-- 한 번 검증해서 걸러냅니다.
local function pickLongestFromEntries(entries, expectedStartChar)
    if not entries then return nil end
    -- 단일 패스: 최대 길이 추적 + 동일 최대 길이 단어만 즉시 수집
    local longest = {}
    local maxLen = 0
    for _, entry in ipairs(entries) do
        local w = type(entry) == "table" and entry.word or entry
        if type(w) == "string" and w ~= ""
            and not isUsed(w) and not isDeleted(w)
            and (not expectedStartChar or firstChar(w) == expectedStartChar) then
            local l = utf8.len(w) or #w
            if l > maxLen then
                -- 새 최대 발견 → 이전 목록 버리고 이 단어부터 시작
                maxLen = l
                longest = {w}
            elseif l == maxLen then
                table.insert(longest, w)
            end
        end
    end
    if #longest == 0 then return nil end
    return longest[math.random(1, #longest)]
end

-- 사전 검색 리모트 결과를 시작 글자별로 캐싱해서, 한 턴 안에서 재시도할
-- 때마다 매번 검색 리모트를 다시 부르지 않도록 합니다(그게 느림의 원인).
-- 검색은 딱 1번만 하고, 재시도는 이 캐시에서 다른 긴 단어를 뽑아 제출만
-- 반복합니다. TurnLetter가 바뀌면(=새 턴 시작) 캐시를 비웁니다.
local function clearRemoteSearchCache()
    -- 모든 글자의 길이순(length) 캐시 초기화
    cacheWords["length"] = {}
    cacheNextPage["length"] = {}
    cacheExhausted["length"] = {}
end

-- 사전 검색 리모트에서 가장 긴 단어를 찾습니다.
-- 현재 로드된 페이지들에서 미사용 최장 단어를 찾고, 없으면 다음 페이지를
-- 한 장씩 추가로 로드하면서 반복합니다. 모든 페이지를 다 썼거나 더 이상
-- 페이지가 없으면 nil을 반환합니다.
local function findLongestWordFromRemote(sc)
    local SORT = "length"
    local variants = getDuumVariants(sc)
    
    -- 1단계: 첫 번째 변형에 대해 최소 1페이지 보장
    local primaryVariant = variants[1]
    ensureFirstPageLoaded(primaryVariant, SORT)

    -- 2단계: 현재 캐시에서 미사용 최장 단어 탐색
    local function tryFindFromCache()
        local words = getCurrentlyLoadedWords(primaryVariant, SORT)
        return pickLongestFromEntries(words, primaryVariant)
    end

    local found = tryFindFromCache()
    if found then return found end

    -- 3단계: 단어를 못 찾았으면 (현재 페이지의 단어를 다 썼으면)
    -- → 다음 페이지로 교체 (이전 페이지 캐시 버림)
    local MAX_RETRY = REMOTE_SEARCH_MAX_PAGES
    for _ = 1, MAX_RETRY do
        -- 아직 고갈 안 됐으면 다음 페이지 로드
        if cacheExhausted[SORT] and not cacheExhausted[SORT][primaryVariant] then
            local added = loadNextPage(primaryVariant, SORT)
            if added > 0 then
                found = tryFindFromCache()
                if found then return found end
            end
        else
            break -- 더 이상 페이지 없음
        end
    end

    -- 4단계: 첫 번째 변형에서 못 찾았으면 두 번째 변형 시도
    if #variants > 1 then
        local altVariant = variants[2]
        ensureFirstPageLoaded(altVariant, SORT)
        
        local function tryFindFromCacheAlt()
            local words = getCurrentlyLoadedWords(altVariant, SORT)
            return pickLongestFromEntries(words, altVariant)
        end
        
        found = tryFindFromCacheAlt()
        if found then return found end
        
        for _ = 1, MAX_RETRY do
            if cacheExhausted[SORT] and not cacheExhausted[SORT][altVariant] then
                local added = loadNextPage(altVariant, SORT)
                if added > 0 then
                    found = tryFindFromCacheAlt()
                    if found then return found end
                end
            else
                break
            end
        end
    end

    return nil
end

-- ============================================================
-- [ 노멀 모드: 검색 리모트로 공격 단어 찾기 ]
-- 게임 사전 검색에는 "공격 단어" 정렬 옵션이 없어서, 여러 페이지를 긁어
-- (스크롤해서 더 불러오는 것과 동일하게 hasMore를 따라 페이지네이션)
-- 후보를 최대한 많이 모은 뒤, 그중 "상대가 답하기 얼마나 어려운지"를
-- 즉석으로 계산해서 가장 공격적인 단어를 고릅니다.
-- 점수 기준: 그 단어의 끝 글자로 시작하는 단어가 검색 리모트상 얼마나
-- 적은지 → 적을수록(0개면 한방 단어) 상대가 막힐 확률이 높은 공격
-- 단어로 판단합니다.
-- ============================================================

-- letter로 시작하는 단어가 몇 개나 있는지(응수 가능 단어 수)를 검색
-- 리모트로 확인합니다. 매번 페이지네이션 전체를 긁으면 느려지므로, 첫
-- 페이지 결과 개수 + hasMore 여부로 대략치를 빠르게 추정합니다.
local replyCountCache = {}

local function estimateReplyCount(letter)
    local cached = replyCountCache[letter]
    if cached ~= nil then return cached end
    local total = 0
    for _, s in ipairs(getDuumVariants(letter)) do
        local words, hasMore = remoteSearchPage(s, "ganada", 0)
        if words then
            total = total + #words
            if hasMore then
                total = total + 50 -- 더 있다는 것만 확인되면 넉넉히 가산(정확한 수 불필요)
            end
        end
    end
    replyCountCache[letter] = total
    return total
end

local function clearReplyCountCache()
    replyCountCache = {}
end

local function attackScoreOf(word)
    -- 끝 글자로 이어갈 수 있는 단어가 적을수록(=상대가 막히기 쉬울수록) 고득점
    local lc = lastChar(word)
    local ec = estimateReplyCount(lc)
    if ec == 0 then
        return 100000 -- 한방 단어(상대가 이을 단어가 아예 없음)
    end
    return -math.min(ec, 200) * 5
end

-- entries에서 아직 안 쓴 것들 중 공격 점수가 가장 높은 것들을 모아
-- 그중 랜덤으로 하나 선택합니다.
-- expectedStartChar로 실제 시작 글자가 맞는지 다시 한 번 검증합니다
-- (검색 리모트가 요청한 글자로 시작하지 않는 단어를 섞어 줄 수 있어서).
local function pickAttackFromEntries(entries, expectedStartChar)
    if not entries then return nil end
    -- 공격 점수 계산 결과 캐시 (같은 턴 안에서 중복 호출 방지)
    local _scoreCache = {}
    local function cachedAttackScore(w)
        if _scoreCache[w] == nil then
            _scoreCache[w] = attackScoreOf(w)
        end
        return _scoreCache[w]
    end
    
    local cands = {}
    local scores = {}
    local seen = {}
    for _, entry in ipairs(entries) do
        local w = type(entry) == "table" and entry.word or entry
        if type(w) == "string" and w ~= "" and not seen[w]
            and not isUsed(w) and not isDeleted(w)
            and (not expectedStartChar or firstChar(w) == expectedStartChar) then
            seen[w] = true
            table.insert(cands, w)
            scores[#cands] = cachedAttackScore(w)
        end
    end
    if #cands == 0 then return nil end

    -- 정렬 대신 상위 5개만 즉석 선택 (전체 정렬보다 빠름)
    local topN = math.min(5, #cands)
    local best = {}
    for i = 1, topN do
        local bestIdx = 1
        for j = 2, #cands do
            if scores[j] > (scores[bestIdx] or -999999) then
                bestIdx = j
            end
        end
        table.insert(best, cands[bestIdx])
        table.remove(cands, bestIdx)
        table.remove(scores, bestIdx)
    end
    return best[math.random(1, #best)]
end

-- 노멀 모드 검색 결과도 한 턴 안에서는 캐싱해서 재검색하지 않습니다.
local function clearNormalSearchCache()
    -- 모든 글자의 가나다순(ganada) 캐시 초기화
    cacheWords["ganada"] = {}
    cacheNextPage["ganada"] = {}
    cacheExhausted["ganada"] = {}
end

-- 노멀 모드: 현재 로드된 페이지들에서 공격 점수 가장 높은 단어를 찾고,
-- 없으면 다음 페이지를 한 장씩 추가로 로드하면서 반복합니다.
local function findAttackWordFromRemote(sc)
    local SORT = "ganada"
    local variants = getDuumVariants(sc)
    
    -- 1단계: 첫 번째 변형에 대해 최소 1페이지 보장
    local primaryVariant = variants[1]
    ensureFirstPageLoaded(primaryVariant, SORT)

    -- 2단계: 현재 캐시에서 최고 공격 단어 탐색
    local function tryFindFromCache()
        local words = getCurrentlyLoadedWords(primaryVariant, SORT)
        return pickAttackFromEntries(words, primaryVariant)
    end

    local found = tryFindFromCache()
    if found then return found end

    -- 3단계: 단어를 못 찾았으면 다음 페이지로 교체
    local MAX_RETRY = REMOTE_SEARCH_MAX_PAGES
    for _ = 1, MAX_RETRY do
        if cacheExhausted[SORT] and not cacheExhausted[SORT][primaryVariant] then
            local added = loadNextPage(primaryVariant, SORT)
            if added > 0 then
                found = tryFindFromCache()
                if found then return found end
            end
        else
            break
        end
    end

    -- 4단계: 첫 번째 변형에서 못 찾았으면 두 번째 변형 시도
    if #variants > 1 then
        local altVariant = variants[2]
        ensureFirstPageLoaded(altVariant, SORT)
        
        local function tryFindFromCacheAlt()
            local words = getCurrentlyLoadedWords(altVariant, SORT)
            return pickAttackFromEntries(words, altVariant)
        end
        
        found = tryFindFromCacheAlt()
        if found then return found end
        
        for _ = 1, MAX_RETRY do
            if cacheExhausted[SORT] and not cacheExhausted[SORT][altVariant] then
                local added = loadNextPage(altVariant, SORT)
                if added > 0 then
                    found = tryFindFromCacheAlt()
                    if found then return found end
                end
            else
                break
            end
        end
    end

    return nil
end

-- ============================================================
-- [ 단어 생성 진입점 ]
-- primaryChar: TurnLetter의 주 글자
-- altChar: 두음 병기("력(역)")의 괄호 안 글자 (없으면 nil)
-- 두 글자 모두에서 후보를 뽑아 비교합니다:
--   - 노멀 모드: 더 어려운(공격적인) 단어 우선
--   - 긴단어 모드: 둘 중 더 긴 단어 우선
-- ============================================================
local function generateWordForChar(sc)
    if mode == "LONG" then
        return findLongestWordFromRemote(sc)
    end
    -- 노멀 모드: 검색 리모트 기반 공격 단어
    return findAttackWordFromRemote(sc)
end

local function pickBetter(curMode, wordA, wordB)
    if not wordA then return wordB end
    if not wordB then return wordA end
    if curMode == "LONG" then
        local la, lb = utf8.len(wordA) or #wordA, utf8.len(wordB) or #wordB
        if la ~= lb then return la > lb and wordA or wordB end
        return wordA
    end
    -- 노멀 모드는 이미 공격 점수순으로 골랐으므로 먼저 나온 것을 그대로 사용
    return wordA
end

local function generateWord(primaryChar, altChar)
    local wordA = generateWordForChar(primaryChar)
    if not altChar then return wordA end
    local wordB = generateWordForChar(altChar)
    return pickBetter(mode, wordA, wordB)
end

-- ============================================================
-- [ 제출 ]
-- 노멀 모드: 1번 쏘고 0.01초 기다려서 확인, 그래도 안 바뀌면 0.01초 간격
--            으로 최대 5번까지(총 5번) 재시도합니다. 실패 시 4개는 다시
--            쓸 수 있게 풀어줍니다.
-- 긴단어 모드: 검색 결과 중 가장 긴 단어를 1번만 제출합니다. 0.01초 후
--             확인만 하고, 안 바뀌어도 재시도하지 않습니다. 제출한
--             단어는 "🗑 리셋"을 누르기 전까지 계속 사용 못 하는 상태로
--             남습니다.
--
-- 단어 딜레이: 최소값~최대값 사이에서 매번 무작위로 하나 골라서 그만큼
-- 기다린 뒤 제출합니다. 최소/최대가 비어있거나 둘 다 0이면 딜레이 없이
-- 거의 즉시 제출합니다.
-- ============================================================
local FIRST_CHECK_DELAY = 0.01    -- 제출 후 변경 여부를 확인하는 대기시간(초)
local FAST_RETRY_DELAY = 0.01     -- 노멀 모드 빠른 재시도 간격(초)
local NORMAL_MAX_SUBMIT_RETRY = 5    -- 노멀 모드 최대 제출 횟수(1번 + 재시도 4번 = 총 5번)
local NORMAL_RESET_COUNT_ON_FAIL = 4 -- 노멀 모드에서 5번 다 썼을 때 다시 풀어줄 단어 개수
local wordDelayMin = 0 -- 단어 딜레이 최소값(초). 비어있거나 0이면 딜레이 없음
local wordDelayMax = 0 -- 단어 딜레이 최대값(초). 비어있거나 0이면 딜레이 없음

local function getWordDelay()
    local mn = tonumber(wordDelayMin) or 0
    local mx = tonumber(wordDelayMax) or 0
    if mn <= 0 and mx <= 0 then return 0 end
    if mn < 0 then mn = 0 end
    if mx < 0 then mx = 0 end
    if mn > mx then mn, mx = mx, mn end
    if mn == mx then return mn end
    return mn + math.random() * (mx - mn)
end

local function submitWord(word, skip)
    local sent = fireSubmitWord(word)
    if not sent then return false end
    usedWords[word] = true
    return true
end

local function doAutoInput()
    local success, err = pcall(function()
        local delay = getWordDelay()
        if delay > 0 then
            task.wait(delay)
        end

        local main, alt = readTurnLetters()
        if not main then
            return
        end
        lastStartChar = main
        -- 캐시는 유지! 매 턴 새로 검색하면 느려짐.
        -- 캐시 초기화가 필요하면 WindUI "🗑 리셋" 버튼으로 수동 처리.

        -- 노멀 모드: 1번 쏘고 0.01초 확인 후 안 바뀌면 최대 5번까지 재시도
        if mode == "NORMAL" then
            local beforeName = getScoreboardTurnName()
            local attemptedWords = {}
            local matched = false

            local firstWord = generateWord(main, alt)
            if firstWord then
                table.insert(attemptedWords, firstWord)
                submitWord(firstWord, true)
                task.wait(FIRST_CHECK_DELAY)

                local afterName = getScoreboardTurnName()
                if beforeName == nil or afterName == nil or afterName ~= beforeName then
                    matched = true
                end
            end

            if not matched then
                for attempt = 2, NORMAL_MAX_SUBMIT_RETRY do
                    local word = generateWord(main, alt)
                    if not word then break end

                    table.insert(attemptedWords, word)
                    submitWord(word, true)

                    task.wait(FAST_RETRY_DELAY)

                    local afterName = getScoreboardTurnName()
                    if beforeName == nil or afterName == nil then
                        matched = true
                        break
                    end
                    if afterName ~= beforeName then
                        matched = true
                        break
                    end
                end
            end

            if not matched and #attemptedWords > 0 then
                for i = #attemptedWords, 2, -1 do
                    local j = math.random(1, i)
                    attemptedWords[i], attemptedWords[j] = attemptedWords[j], attemptedWords[i]
                end
                local resetN = math.min(NORMAL_RESET_COUNT_ON_FAIL, #attemptedWords)
                for i = 1, resetN do
                    usedWords[attemptedWords[i]] = nil
                end
            end
            return
        end

        -- 긴단어 모드(및 그 외 모드): 검색 결과 중 가장 긴 단어를 1번만 제출.
        -- 0.01초 후 확인만 하고, 안 바뀌어도 재시도하지 않습니다. 제출한
        -- 단어는 submitWord()에서 이미 usedWords에 기록되므로, "🗑 리셋"
        -- 버튼을 누르기 전까지는 계속 사용 못 하는 상태로 남습니다.
        local word = generateWord(main, alt)
        if word then
            submitWord(word, true)
            task.wait(FIRST_CHECK_DELAY)
        end
    end)
    if not success then warn(err) end
end

