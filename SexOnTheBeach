do
    local WINDUI_URL = "https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"
    local WINDUI_LOAD_TIMEOUT = 8 -- 초
    local lastErr = nil

    for attempt = 1, 3 do
        local finished = false
        local loadOk, loadResult = false, nil

        task.spawn(function()
            local ok, result = pcall(function()
                local src = game:HttpGet(WINDUI_URL)
                local chunk = loadstring(src)
                if not chunk then error("loadstring이 nil을 반환함 (다운로드된 코드가 손상됐을 수 있음)") end
                return chunk()
            end)
            loadOk, loadResult = ok, result
            finished = true
        end)

        local waited = 0
        while not finished and waited < WINDUI_LOAD_TIMEOUT do
