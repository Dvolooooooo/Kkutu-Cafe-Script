local isLoadingWords = false

-- 사전 로드 + 점수 계산 + N-kill 확장을 한 번에 수행. 단어목록 ON/OFF 토글이나
-- 최초 실행 시 공용으로 호출합니다.
reloadDictionary = function(notifyLabel)
    if isLoadingWords then return end
    isLoadingWords = true
    local total = loadWords()
    calcScores()
    if maxRoute >= 3 then
        local killable2 = {}
        for sc, wl in pairs(dictionary) do
            for _, w in ipairs(wl) do
                if (wordScore[w] or 0) >= 10000 then killable2[sc] = true; break end
            end
        end
        for _, wl in pairs(dictionary) do
            for _, word in ipairs(wl) do
                if (wordScore[word] or 0) < 10000 then
                    local lc = lastChar(word)
                    local opEnds = {}; local seenOLC = {}; local tooMany = false
                    for _, v in ipairs(getDuumVariants(lc)) do
                        if tooMany then break end
                        local ol = dictionary[v]
                        if ol then
                            for _, ow in ipairs(ol) do
                                local o = lastChar(ow)
                                if not seenOLC[o] then
                                    seenOLC[o] = true
                                    table.insert(opEnds, o)
                                    if #opEnds >= 25 then tooMany = true; break end
                                end
                            end
                        end
                    end
                    if not tooMany and #opEnds > 0 then
                        local ok = true
                        for _, o in ipairs(opEnds) do
                            local c = false
                            for _, v in ipairs(getDuumVariants(o)) do
                                if killable2[v] then c = true; break end
                            end
                            if not c then ok = false; break end
                        end
                        if ok then wordScore[word] = 5000 + (wordScore[word] or 0) end
                    end
                end
            end
        end
    end
    WindUI:Notify({Title = "✅ " .. (notifyLabel or "로드 완료"), Content = "단어 " .. total .. "개 로드 & 점수 계산 완료", Duration = 5})
    isLoadingWords = false
end

