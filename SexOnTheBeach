    local WINDUI_LOAD_TIMEOUT = 8 -- 초
    local lastErr = nil

    for attempt = 1, 3 do
        local finished = false
        local loadOk, loadResult = false, nil

        task.spawn(function()
            local ok, result = pcall(function()
                local src = game:HttpGet(WINDUI_URL)
